---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    emoji: '🤖',
    name: 'BI Copilot',
    tagline: 'Agente de BI conversacional',
    description:
      'Pergunte indicadores comerciais em linguagem natural e receba relatórios prontos. O agente raciocina, escolhe a ferramenta certa (camada semântica ou SQL), aplica segurança de acesso em código e responde em português.',
    stack: ['LangGraph', 'GPT-5.4-mini', 'RAG / ChromaDB', 'Cube.js', 'FastAPI'],
    repo: 'https://github.com/RaulRMO10/BI_COPILOT',
    flagship: true,
  },
  {
    emoji: '🦷',
    name: 'OdontoSystem',
    tagline: 'Gestão de consultório (full-stack)',
    description:
      'Sistema completo para consultórios odontológicos: agenda, prontuário, odontograma, anamnese, controle protético e gestão financeira — com autenticação por perfis e API documentada.',
    stack: ['FastAPI', 'React', 'Vite', 'Tailwind', 'Supabase'],
    repo: 'https://github.com/RaulRMO10/consultorio-dentista',
    flagship: false,
  },
  {
    emoji: '🏋️',
    name: 'Minha Rotina',
    tagline: 'Dashboard pessoal de dieta & treino',
    description:
      'App pessoal que centraliza refeições, metas de macros, treinos e compras, com dados nutricionais reais buscados via API e sincronização na nuvem.',
    stack: ['JavaScript', 'Supabase', 'FatSecret API'],
    repo: 'https://github.com/RaulRMO10/rotina',
    flagship: false,
  },
];

const skills = [
  {
    group: 'Dados & BI',
    items: ['SQL Oracle', 'Oracle APEX', 'Power BI', 'Pandas', 'Excel', 'Modelagem analítica'],
  },
  {
    group: 'IA & Machine Learning',
    items: ['LLMs', 'IA Generativa', 'Agentes (LangGraph)', 'RAG', 'LangChain', 'Classificação & Regressão'],
  },
  {
    group: 'Desenvolvimento',
    items: ['Python', 'FastAPI', 'React', 'JavaScript', 'Supabase', 'Cube.js'],
  },
];

const education = [
  { school: 'FIAP', course: 'Pós-graduação (Lato Sensu) em Agentes de IA', period: 'jun 2026 – abr 2027 · em andamento', highlight: true },
  { school: 'Estácio', course: 'Tecnólogo em Ciência de Dados', period: 'jan 2023 – jul 2025' },
  { school: 'Escola DNC', course: 'Formação em Dados — Ciência de Dados', period: 'fev 2024 – out 2024' },
  { school: 'Instituto Federal de Goiás (IFG)', course: 'Técnico em Meio Ambiente', period: '2017 – 2018' },
];

const GITHUB = 'https://github.com/RaulRMO10';
const LINKEDIN = 'https://www.linkedin.com/in/raulrmo/';
const EMAIL = 'raulmartinsagrivet1@gmail.com';
const WHATSAPP = 'https://wa.me/5564992919297';
---

<Layout>
  <!-- NAV -->
  <header class="fixed inset-x-0 top-0 z-50 border-b border-white/5 bg-ink-950/80 backdrop-blur">
    <nav class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
      <a href="#top" class="font-bold text-white tracking-tight">Raul<span class="text-accent">.</span></a>
      <div class="hidden gap-8 text-sm md:flex">
        <a href="#sobre" class="hover:text-white transition">Sobre</a>
        <a href="#projetos" class="hover:text-white transition">Projetos</a>
        <a href="#skills" class="hover:text-white transition">Stack</a>
        <a href="#formacao" class="hover:text-white transition">Formação</a>
        <a href="#contato" class="hover:text-white transition">Contato</a>
      </div>
      <a href={GITHUB} target="_blank" rel="noopener"
        class="rounded-full border border-white/10 px-4 py-1.5 text-sm text-white hover:border-accent hover:text-accent transition">GitHub</a>
    </nav>
  </header>

  <main id="top" class="mx-auto max-w-5xl px-6">
    <!-- HERO -->
    <section class="flex min-h-screen flex-col justify-center py-28">
      <p class="animate-fade-up text-accent font-medium">Olá, eu sou</p>
      <h1 class="animate-fade-up mt-3 text-5xl font-extrabold tracking-tight text-white sm:text-6xl md:text-7xl">
        Raul Martins
      </h1>
      <h2 class="animate-fade-up mt-4 text-2xl font-semibold text-slate-400 sm:text-3xl">
        Analista de Dados <span class="text-accent">→</span> Engenheiro de Agentes de IA
      </h2>
      <p class="animate-fade-up mt-6 max-w-2xl text-lg leading-relaxed text-slate-400">
        Transformo grandes volumes de dados em indicadores e produtos — e levo
        <strong class="text-slate-200">IA generativa, LLMs e agentes</strong> para dentro da análise de dados.
        Atualmente Analista de Dados Pleno e pós-graduando em <strong class="text-slate-200">Agentes de IA na FIAP</strong>.
      </p>
      <div class="animate-fade-up mt-10 flex flex-wrap gap-4">
        <a href="#projetos"
          class="rounded-full bg-accent px-6 py-3 font-semibold text-ink-950 hover:bg-accent-soft transition">
          Ver projetos
        </a>
        <a href={LINKEDIN} target="_blank" rel="noopener"
          class="rounded-full border border-white/15 px-6 py-3 font-semibold text-white hover:border-accent hover:text-accent transition">
          LinkedIn
        </a>
        <a href="#contato"
          class="rounded-full border border-white/15 px-6 py-3 font-semibold text-white hover:border-accent hover:text-accent transition">
          Contato
        </a>
      </div>
      <p class="animate-fade-up mt-10 text-sm text-slate-500">📍 Goiânia, GO · Brasil</p>
    </section>

    <!-- SOBRE -->
    <section id="sobre" class="border-t border-white/5 py-24">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">Sobre</h2>
      <div class="mt-6 grid gap-10 md:grid-cols-3">
        <p class="text-2xl font-semibold leading-snug text-white md:col-span-2">
          Da consulta SQL ao agente de IA — construo soluções de dados que apoiam decisões reais.
        </p>
        <div class="space-y-4 text-slate-400 md:col-span-3 md:max-w-3xl">
          <p>
            Sou <strong class="text-slate-200">Analista de Dados Pleno</strong>, com atuação em ambiente corporativo
            especializado em <strong class="text-slate-200">SQL Oracle, Oracle APEX e Python</strong>. Transformo
            grandes volumes de dados em dashboards, indicadores e análises que apoiam decisões estratégicas,
            desempenho comercial e eficiência operacional.
          </p>
          <p>
            Hoje direciono minha evolução para <strong class="text-slate-200">inteligência artificial aplicada</strong>
            — Machine Learning, IA generativa e agentes de IA —, formação que aprofundo na
            <strong class="text-slate-200">pós-graduação em Agentes de IA pela FIAP</strong>. Meu projeto principal,
            o <strong class="text-slate-200">BI Copilot</strong>, é exatamente essa ponte: um agente de IA que conversa
            com os dados de negócio.
          </p>
        </div>
      </div>
    </section>

    <!-- PROJETOS -->
    <section id="projetos" class="border-t border-white/5 py-24">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">Projetos em destaque</h2>
      <div class="mt-10 grid gap-6">
        {projects.map((p) => (
          <article class={`group rounded-2xl border p-7 transition hover:-translate-y-1 ${p.flagship ? 'border-accent/40 bg-ink-800/60' : 'border-white/10 bg-ink-900/60 hover:border-white/20'}`}>
            <div class="flex flex-wrap items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <span class="text-3xl">{p.emoji}</span>
                <div>
                  <h3 class="text-xl font-bold text-white">{p.name}</h3>
                  <p class="text-sm text-slate-400">{p.tagline}</p>
                </div>
              </div>
              {p.flagship && (
                <span class="rounded-full bg-accent/15 px-3 py-1 text-xs font-semibold text-accent">★ Carro-chefe</span>
              )}
            </div>
            <p class="mt-5 leading-relaxed text-slate-400">{p.description}</p>
            <div class="mt-5 flex flex-wrap gap-2">
              {p.stack.map((t) => (
                <span class="rounded-md border border-white/10 bg-white/5 px-2.5 py-1 text-xs text-slate-300">{t}</span>
              ))}
            </div>
            <div class="mt-6">
              <a href={p.repo} target="_blank" rel="noopener"
                class="inline-flex items-center gap-2 text-sm font-semibold text-accent hover:text-accent-soft transition">
                Ver código no GitHub
                <span class="transition group-hover:translate-x-1">→</span>
              </a>
            </div>
          </article>
        ))}
      </div>
    </section>

    <!-- SKILLS -->
    <section id="skills" class="border-t border-white/5 py-24">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">Stack & competências</h2>
      <div class="mt-10 grid gap-6 sm:grid-cols-3">
        {skills.map((s) => (
          <div class="rounded-2xl border border-white/10 bg-ink-900/60 p-6">
            <h3 class="font-semibold text-white">{s.group}</h3>
            <ul class="mt-4 space-y-2">
              {s.items.map((i) => (
                <li class="flex items-center gap-2 text-sm text-slate-400">
                  <span class="text-accent">▸</span>{i}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- FORMAÇÃO -->
    <section id="formacao" class="border-t border-white/5 py-24">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">Formação</h2>
      <div class="mt-10 space-y-4">
        {education.map((e) => (
          <div class={`flex flex-wrap items-baseline justify-between gap-2 rounded-xl border p-5 ${e.highlight ? 'border-accent/40 bg-ink-800/40' : 'border-white/10 bg-ink-900/40'}`}>
            <div>
              <h3 class="font-semibold text-white">
                {e.school}
                {e.highlight && <span class="ml-2 rounded bg-accent/15 px-2 py-0.5 text-xs text-accent">em foco</span>}
              </h3>
              <p class="text-sm text-slate-400">{e.course}</p>
            </div>
            <span class="text-sm text-slate-500">{e.period}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- CONTATO -->
    <section id="contato" class="border-t border-white/5 py-24 text-center">
      <h2 class="text-sm font-semibold uppercase tracking-widest text-accent">Contato</h2>
      <p class="mx-auto mt-6 max-w-xl text-2xl font-semibold text-white">
        Vamos conversar sobre dados e IA?
      </p>
      <p class="mt-3 text-slate-400">Aberto a oportunidades e projetos em Dados & Agentes de IA.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href={WHATSAPP} target="_blank" rel="noopener"
          class="rounded-full bg-[#25D366] px-6 py-3 font-semibold text-ink-950 hover:brightness-110 transition">
          💬 WhatsApp
        </a>
        <a href={`mailto:${EMAIL}`}
          class="rounded-full bg-accent px-6 py-3 font-semibold text-ink-950 hover:bg-accent-soft transition">
          E-mail
        </a>
        <a href={LINKEDIN} target="_blank" rel="noopener"
          class="rounded-full border border-white/15 px-6 py-3 font-semibold text-white hover:border-accent hover:text-accent transition">
          LinkedIn
        </a>
        <a href={GITHUB} target="_blank" rel="noopener"
          class="rounded-full border border-white/15 px-6 py-3 font-semibold text-white hover:border-accent hover:text-accent transition">
          GitHub
        </a>
      </div>
      <p class="mt-6 text-sm text-slate-500">📱 (64) 99291-9297</p>
    </section>
  </main>

  <footer class="border-t border-white/5 py-8 text-center text-sm text-slate-500">
    © {new Date().getFullYear()} Raul Martins Oliveira · Feito com Astro & Tailwind CSS
  </footer>
</Layout>
